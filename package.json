{
  "name": "bovcontrol",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "node scripts/pin-node-modules.js",
    "predev": "node scripts/setup-dev-junctions.js",
    "postinstall": "node scripts/move-nm-to-temp.js",
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:dev": "tsx prisma/seed-dev.ts",
    "db:reset": "prisma migrate reset --force",
    "db:reset:dev": "tsx scripts/reset-dev.ts",
    "db:fresh:dev": "npm run db:push && npm run db:seed && npm run db:seed:dev",
    "storage:audit": "tsx scripts/storage-audit.ts",
    "storage:fix": "tsx scripts/storage-audit.ts --fix",
    "storage:migrate": "tsx scripts/storage-migrate.ts",
    "storage:migrate:dry": "tsx scripts/storage-migrate.ts --dry-run",
    "deploy:check": "tsc --noEmit && next build",
    "db:migrate:prod": "prisma migrate deploy",
    "production:prepare": "tsx scripts/production-setup.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "^3.1055.0",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.15",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.453.0",
    "next": "^15.3.9",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/qrcode": "^1.5.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
