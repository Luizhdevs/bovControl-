# ─── Banco de dados ────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/bovcontrol"

# ─── Auth.js ───────────────────────────────────────────────
# Gerar: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── Cloudflare R2 (upload de fotos — produção) ─────────────
# Account ID: dash.cloudflare.com → R2 → Account ID (sidebar)
R2_ACCOUNT_ID="your-account-id"
# Criar API Token em: R2 → Manage R2 API Tokens → Create API Token
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
# Nome do bucket criado no R2
R2_BUCKET_NAME="bovcontrol-photos"
# URL pública do bucket (ativar em: Bucket Settings → Public Access)
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# ─── Next.js ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
