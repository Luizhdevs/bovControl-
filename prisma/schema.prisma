generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH (Auth.js v5) ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  farmUsers    FarmUser[]
  sentInvites  Invite[]      @relation("InviteCreator")
  feedSessions FeedSession[] @relation("FeedCreator")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── FARM ──────────────────────────────────────────────────

model Farm {
  id        String   @id @default(cuid())
  name      String
  city      String?
  state     String   @default("MG")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Controle de armazenamento ───────────────────────────
  storageUsedMb Float @default(0)
  imageCount    Int   @default(0)

  users               FarmUser[]
  animals             Animal[]
  lots                Lot[]
  pastures            Pasture[]
  alerts              Alert[]
  invites             Invite[]
  milkingSessions     MilkingSession[]
  feedTypes           FeedType[]
  feedSessions        FeedSession[]
  settings            FarmSettings?
  earTagTemplates     EarTagTemplate[]
  veterinaryReports   VeterinaryReport[]
  veterinarySnapshots VeterinaryAnimalSnapshot[]

  @@map("farms")
}

// ─── CONFIGURAÇÕES DA FAZENDA ──────────────────────────────
// Parâmetros operacionais configuráveis sem alterar código.
// Criado automaticamente no primeiro acesso via getOrCreateFarmSettings().

model FarmSettings {
  id     String @id @default(cuid())
  farmId String @unique

  // Lote principal de produção leiteira (escolha explícita do operador)
  mainProductionLotId String?

  // Feature flags operacionais
  enableMilkParticipants Boolean @default(true) // habilita seleção de participantes da ordenha
  autoUpdateMilkStatus   Boolean @default(true) // atualiza milkStatus ao mover animal de lote
  useEstimatedMilkPerCow Boolean @default(true) // distribui litros proporcionalmente por vaca

  // ── Parâmetros do módulo veterinário ─────────────────────
  // Todos nullable — se null, o sistema usa os padrões definidos em constants.ts
  ccsAlertThreshold Float? // CCS x 1000 para disparar alerta HIGH_CCS
  mastitisDaysAlert Int? // Dias de mamite para disparar MASTITIS_FOLLOW_UP
  emptyDaysAlert    Int? // Dias vazia para classificar como EMPTY_COW_LATE

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farm              Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  mainProductionLot Lot? @relation("MainProductionLot", fields: [mainProductionLotId], references: [id])

  @@map("farm_settings")
}

model FarmUser {
  id       String   @id @default(cuid())
  farmId   String
  userId   String
  role     UserRole @default(WORKER)
  joinedAt DateTime @default(now())

  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([farmId, userId])
  @@map("farm_users")
}

// ─── ANIMAL ────────────────────────────────────────────────

model Animal {
  id           String       @id @default(cuid())
  farmId       String
  tag          String // Brinco gerado automaticamente: BOV-0001
  name         String?
  sex          Sex
  category     Category
  breed        String       @default("Mestiço")
  status       AnimalStatus @default(ACTIVE)
  purpose      Purpose      @default(DAIRY)
  birthDate    DateTime?
  // birthType rastreia origem do animal — usado para regra:
  // fêmea de INSEMINATION não pode ir para abate antes de virar vaca
  birthType    BirthType?
  entryDate    DateTime     @default(now())
  exitDate     DateTime?
  exitReason   String?
  motherId     String?
  fatherId     String?
  lotId        String?
  milkStatus   MilkStatus   @default(NA)
  observations String?      @db.Text
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Acumuladores de ração — atualizados em $transaction em cada FeedSession
  totalFeedConsumedKg Float @default(0)
  estimatedFeedCost   Float @default(0)

  // ── Dados veterinários externos ──────────────────────────
  // Atualizados somente após revisão e confirmação de import veterinário.
  // Nunca sobrescrever sem checar se o valor do relatório é mais recente.
  externalCode           String? // Identificador no sistema PRODAP/ZIL (≠ BOV-XXXX)
  parityNumber           Int? // Número de partos — atualizado a cada CALVING confirmado
  lastCalvingDate        DateTime? // Data do último parto confirmado
  lastVeterinaryReportAt DateTime? // Quando o último relatório veterinário incluiu este animal
  lastCcsThousand        Float? // CCS mais recente (x 1000) — para alertas rápidos no dashboard

  farm             Farm     @relation(fields: [farmId], references: [id])
  lot              Lot?     @relation(fields: [lotId], references: [id])
  mother           Animal?  @relation("Mother", fields: [motherId], references: [id])
  maternalChildren Animal[] @relation("Mother")
  father           Animal?  @relation("Father", fields: [fatherId], references: [id])
  paternalChildren Animal[] @relation("Father")

  photos              AnimalPhoto[]
  weightRecords       WeightRecord[]
  healthEvents        HealthEvent[]
  milkRecords         MilkRecord[]
  milkParticipations  MilkingSessionParticipant[]
  reproductions       Reproduction[]
  alerts              Alert[]
  feedConsumptions    AnimalFeedConsumption[]
  veterinarySnapshots VeterinaryAnimalSnapshot[]

  @@unique([farmId, tag])
  @@index([farmId, status])
  @@index([farmId, category])
  @@index([farmId, createdAt])
  @@index([farmId, lotId])
  @@index([motherId])
  @@index([fatherId])
  @@index([farmId, externalCode]) // match rápido na importação veterinária
  @@index([farmId, lastCalvingDate]) // dashboard reprodutivo — dias pós-parto
  @@map("animals")
}

model AnimalPhoto {
  id           String   @id @default(cuid())
  animalId     String
  url          String // URL da imagem original otimizada
  thumbnailUrl String? // URL do thumbnail 300px (gerado automaticamente)
  caption      String?
  takenAt      DateTime @default(now())
  isPrimary    Boolean  @default(false)
  sizeKb       Int      @default(0) // Tamanho em KB (original + thumb combinados)

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, takenAt])
  @@map("animal_photos")
}

model WeightRecord {
  id         String   @id @default(cuid())
  animalId   String
  weightKg   Float
  measuredAt DateTime @default(now())
  notes      String?

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, measuredAt])
  @@map("weight_records")
}

model HealthEvent {
  id          String          @id @default(cuid())
  animalId    String
  type        HealthEventType
  description String
  medication  String?
  cost        Float?
  occurredAt  DateTime        @default(now())
  resolved    Boolean         @default(false)
  notes       String?         @db.Text

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, occurredAt])
  @@map("health_events")
}

// ─── LOTES E PASTOS ────────────────────────────────────────

model Lot {
  id          String   @id @default(cuid())
  farmId      String
  name        String
  type        LotType  @default(MIXED)
  maxCapacity Int?
  pastureId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  observations String? @db.Text

  farm               Farm           @relation(fields: [farmId], references: [id])
  pasture            Pasture?       @relation(fields: [pastureId], references: [id])
  animals            Animal[]
  feedSessions       FeedSession[]
  farmSettingsAsMain FarmSettings[] @relation("MainProductionLot")

  @@unique([farmId, name])
  @@map("lots")
}

model Pasture {
  id           String   @id @default(cuid())
  farmId       String
  name         String
  areaHectares Float?
  grassType    String?
  maxCapacity  Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  farm Farm  @relation(fields: [farmId], references: [id])
  lots Lot[]

  @@unique([farmId, name])
  @@map("pastures")
}

// ─── REPRODUÇÃO ────────────────────────────────────────────

model Reproduction {
  id            String             @id @default(cuid())
  animalId      String
  type          ReproductionType
  status        ReproductionStatus @default(PENDING)
  date          DateTime
  // bullName = nome do touro (monta natural) ou identificação do sêmen (IA)
  bullName      String?
  result        String?
  nextCheckDate DateTime?
  notes         String?
  createdAt     DateTime           @default(now())

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([animalId, type, date])
  @@map("reproductions")
}

// ─── PRODUÇÃO DE LEITE ─────────────────────────────────────

model MilkRecord {
  id             String    @id @default(cuid())
  animalId       String
  farmId         String
  liters         Float
  shift          MilkShift
  recordedAt     DateTime  @default(now())
  // Para deduplicação de sync offline: o cliente gera UUID; o servidor
  // rejeita duplicatas silenciosamente e retorna o registro existente.
  idempotencyKey String?   @unique @map("idempotency_key")

  animal Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@index([farmId, recordedAt])
  @@index([animalId, recordedAt])
  @@map("milk_records")
}

// ─── ORDENHA POR SESSÃO ────────────────────────────────────
// Cada registro = 1 ordenha (manhã ou tarde) para toda a fazenda.
// Substitui o registro individual por animal na UI — MilkRecord permanece
// intacto para futura rastreabilidade individual (Fase 2).

model MilkingSession {
  id             String    @id @default(cuid())
  farmId         String
  shift          MilkShift
  date           DateTime  @db.Date
  totalLiters    Float
  milkingCows    Int
  notes          String?
  // Deduplicação de sync offline: cliente gera UUID antes de enviar
  idempotencyKey String?   @unique @map("idempotency_key")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  farm         Farm                        @relation(fields: [farmId], references: [id], onDelete: Cascade)
  participants MilkingSessionParticipant[]

  // Uma fazenda só pode ter 1 sessão por turno por dia
  @@unique([farmId, shift, date])
  @@index([farmId, date])
  @@map("milking_sessions")
}

// ─── PARTICIPANTES DA ORDENHA ──────────────────────────────

model MilkingSessionParticipant {
  id             String   @id @default(cuid())
  sessionId      String
  animalId       String
  liters         Float?
  isEstimated    Boolean  @default(true)
  idempotencyKey String?  @unique @map("idempotency_key")
  createdAt      DateTime @default(now())

  session MilkingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  animal  Animal         @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@unique([sessionId, animalId])
  @@index([animalId, createdAt])
  @@map("milking_session_participants")
}

// ─── NUTRIÇÃO / RAÇÃO ─────────────────────────────────────

model FeedType {
  id             String   @id @default(cuid())
  farmId         String
  name           String
  brand          String?
  weightPerBagKg Float
  pricePerBag    Float
  proteinPercent Float?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  farm         Farm          @relation(fields: [farmId], references: [id])
  feedSessions FeedSession[]

  @@index([farmId, active])
  @@map("feed_types")
}

// Uma FeedSession = 1 evento de alimentação de um lote inteiro.
// animalCount é snapshot do momento do registro — preserva histórico.

model FeedSession {
  id                   String   @id @default(cuid())
  farmId               String
  lotId                String
  feedTypeId           String
  date                 DateTime @db.Date
  bagCount             Int
  totalWeightKg        Float
  totalCost            Float
  animalCount          Int
  averageKgPerAnimal   Float
  averageCostPerAnimal Float
  notes                String?
  createdById          String
  createdAt            DateTime @default(now())

  farm         Farm                    @relation(fields: [farmId], references: [id])
  lot          Lot                     @relation(fields: [lotId], references: [id])
  feedType     FeedType                @relation(fields: [feedTypeId], references: [id])
  createdBy    User                    @relation("FeedCreator", fields: [createdById], references: [id])
  consumptions AnimalFeedConsumption[]

  @@index([farmId, date])
  @@index([lotId, date])
  @@map("feed_sessions")
}

model AnimalFeedConsumption {
  id            String   @id @default(cuid())
  animalId      String
  feedSessionId String
  consumedKg    Float
  estimatedCost Float
  createdAt     DateTime @default(now())

  animal      Animal      @relation(fields: [animalId], references: [id], onDelete: Cascade)
  feedSession FeedSession @relation(fields: [feedSessionId], references: [id], onDelete: Cascade)

  @@index([animalId, createdAt])
  @@map("animal_feed_consumptions")
}

// ─── CONVITES ──────────────────────────────────────────────

model Invite {
  id          String       @id @default(cuid())
  farmId      String
  email       String
  role        UserRole     @default(WORKER)
  token       String       @unique
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime
  usedAt      DateTime?
  createdById String
  createdAt   DateTime     @default(now())

  farm      Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)
  createdBy User @relation("InviteCreator", fields: [createdById], references: [id])

  @@index([farmId, status])
  @@index([email, status])
  @@map("invites")
}

// ─── AUDITORIA ─────────────────────────────────────────────
// Append-only. Nunca deletar entradas de audit.
// farmId/userId são strings diretas — sem FK para evitar CASCADE acidental.

model AuditLog {
  id        String   @id @default(cuid())
  farmId    String
  userId    String
  action    String // 'CREATE' | 'UPDATE' | 'DELETE'
  entity    String // 'MilkRecord' | 'HealthEvent' | 'Animal' | etc.
  entityId  String
  before    Json?
  after     Json?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([farmId, entity, createdAt])
  @@index([entityId])
  @@map("audit_logs")
}

// ─── ALERTAS ───────────────────────────────────────────────

model Alert {
  id          String      @id @default(cuid())
  farmId      String
  animalId    String?
  type        AlertType
  title       String
  description String?
  priority    Priority    @default(MEDIUM)
  status      AlertStatus @default(PENDING)
  dueDate     DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())

  farm   Farm    @relation(fields: [farmId], references: [id])
  animal Animal? @relation(fields: [animalId], references: [id])

  @@index([farmId, status])
  @@map("alerts")
}

// ─── ETIQUETAS DE BRINCO ────────────────────────────────────

model EarTagTemplate {
  id     String @id @default(cuid())
  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  name String

  widthMm   Float @default(50)
  heightMm  Float @default(25)
  paddingMm Float @default(3)

  fontSizeMain      Int @default(14)
  fontSizeSecondary Int @default(9)

  qrSizeMm Float @default(18)

  showAnimalName Boolean @default(false)
  showAnimalTag  Boolean @default(true)
  showFarmName   Boolean @default(false)
  showBorder     Boolean @default(true)

  orientation String @default("landscape")
  bgColor     String @default("#FFFFFF")
  textColor   String @default("#000000")

  layoutJson Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([farmId])
  @@map("ear_tag_templates")
}

// ─── RELATÓRIO VETERINÁRIO ─────────────────────────────────
// Cabeçalho de cada importação de relatório veterinário (PRODAP/ZIL).
// Imutável após status = IMPORTED.
// importedByUserId sem FK — append-only, como AuditLog, sobrevive a deleções.

model VeterinaryReport {
  id                String                 @id @default(cuid())
  farmId            String
  reportDate        DateTime               @db.Date
  sourceSystem      VeterinaryReportSource @default(PRODAP)
  technicianName    String?
  externalFarmName  String? // Nome da fazenda como consta no relatório
  externalOwnerName String? // Proprietário como consta no relatório
  originalFilename  String?
  originalFileUrl   String? // R2 URL do arquivo original
  importStatus      VeterinaryReportStatus @default(DRAFT)
  totalRows         Int                    @default(0)
  matchedRows       Int                    @default(0)
  unmatchedRows     Int                    @default(0)
  importedByUserId  String // sem FK — append-only como AuditLog
  metadata          Json? // dados extras: avisos, linhas puladas, etc.
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  farm      Farm                       @relation(fields: [farmId], references: [id])
  snapshots VeterinaryAnimalSnapshot[]

  @@index([farmId, reportDate])
  @@map("veterinary_reports")
}

// ─── SNAPSHOT DO ANIMAL NO RELATÓRIO ──────────────────────
// Foto dos dados de cada animal na data do relatório veterinário.
// Imutável após importação confirmada.
// animalId é nullable: null = linha não encontrou match no cadastro.
// rp e sx são String? — valor bruto do relatório, sem interpretação veterinária.

model VeterinaryAnimalSnapshot {
  id       String  @id @default(cuid())
  farmId   String
  reportId String
  animalId String? // nullable: null = não encontrado no cadastro

  // Identificação no relatório
  externalCode String?
  animalName   String?

  // Grupo operacional
  reportGroup   VeterinaryReportGroup @default(UNKNOWN)
  rawGroupLabel String? // label original do relatório

  // Dados reprodutivos do snapshot
  parityNumber        Int?
  lastCalvingDate     DateTime?
  rp                  String? // retenção de placenta — valor bruto (ex: "Sim", "1", "S")
  sx                  String? // escore de descarga — valor bruto (ex: "1", "2", "3")
  inseminationDate    DateTime?
  inseminationNumber  Int? // 1ª, 2ª, 3ª IA
  reportDays          Int? // campo "Dias" — significado definido por dayMeaning
  dayMeaning          VeterinaryDayMeaning @default(UNKNOWN)
  bullName            String?
  expectedCalvingDate DateTime?

  // Dados produtivos do snapshot
  milkPeak    Float? // leite pico da secagem
  milkCurrent Float? // leite produção atual da secagem

  // Cadastro no relatório
  breed      String?
  fatherName String? // nome do pai como texto livre (pode não ser animal do sistema)

  // Escores veterinários
  cScore Float? // condição corporal (C)
  tScore Float? // escore de tetas/úbere (T)

  // Ocorrências e recomendações
  occurrence            String?
  discardRecommendation String? // recomendação de descarte — texto livre do técnico
  mastitisDays          Int? // dias com mamite nesta secagem
  ccsThousand           Float? // CCS x 1000

  isCloseUp Boolean  @default(false) // amojada — identificada visualmente no relatório
  rawRow    Json? // linha original para auditoria e re-parsing
  createdAt DateTime @default(now())

  farm   Farm             @relation(fields: [farmId], references: [id])
  report VeterinaryReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  animal Animal?          @relation(fields: [animalId], references: [id])

  @@index([farmId, reportId])
  @@index([farmId, animalId, createdAt])
  @@index([farmId, reportGroup])
  @@index([farmId, expectedCalvingDate])
  @@index([reportId])
  @@map("veterinary_animal_snapshots")
}

// ─── ENUMS ─────────────────────────────────────────────────

enum UserRole {
  OWNER
  MANAGER
  WORKER
  VIEWER
}

enum Sex {
  MALE
  FEMALE
}

enum Purpose {
  DAIRY
  BEEF
  BOTH
}

enum AnimalStatus {
  ACTIVE
  SOLD
  DEAD
  TRANSFERRED
}

enum Category {
  CALF
  HEIFER
  COW
  BULL
  STEER
}

// BirthType: rastreia origem do animal para regras reprodutivas futuras
enum BirthType {
  NATURAL
  INSEMINATION
  EMBRYO_TRANSFER
}

enum LotType {
  LACTATING
  DRY
  HEIFER
  CALF
  FATTENING
  MIXED
  MATERNITY
  BREEDING
}

enum MilkStatus {
  LACTATING // vaca em produção ativa
  DRY // vaca seca
  DRY_PREGNANT // vaca seca e gestante (milkStatus DRY + PREGNANCY_CHECK CONFIRMED)
  HEIFER // novilha (ainda não pariu)
  NA // não se aplica (machos, bezerros, etc.)
}

enum HealthEventType {
  VACCINATION
  DISEASE
  DEWORMING
  EXAM
  MEDICATION
  MASTITIS // mamite como tipo específico — permite filtros e alertas dedicados
  OTHER
}

enum ReproductionType {
  INSEMINATION
  NATURAL_MATING
  PREGNANCY_CHECK
  CALVING // parto confirmado — fonte primária para parityNumber e lastCalvingDate
}

enum ReproductionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum MilkShift {
  MORNING
  AFTERNOON
}

enum AlertType {
  HEAT
  PREGNANCY_CHECK
  DRY_OFF
  CALVING
  VACCINATION
  WEIGHT_CHECK
  // ── Módulo veterinário ─────────────────────────────────
  PREGNANCY_CHECK_DUE // diagnóstico de gestação pendente (> 30 dias de IA)
  DRY_OFF_DUE // animal deve ser seca (≤ 60 dias para parto previsto)
  CALVING_SOON // parto previsto em ≤ 15 dias
  CALVING_OVERDUE // parto previsto passou sem registro de CALVING
  EMPTY_COW_LATE // vaca vazia atrasada (> emptyDaysAlert dias sem IA)
  HIGH_CCS // CCS acima de ccsAlertThreshold
  MASTITIS_FOLLOW_UP // acompanhamento de mamite ativa
  DISCARD_REVIEW // animal recomendada para descarte pelo técnico
}

enum AlertStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// ─── ENUMS DO MÓDULO VETERINÁRIO ──────────────────────────

enum VeterinaryReportSource {
  PRODAP
  ZIL
  MANUAL
  CSV
  OTHER
}

enum VeterinaryReportStatus {
  DRAFT // arquivo carregado, ainda não confirmado
  IMPORTED // todos os rows matched e importados
  PARTIALLY_IMPORTED // alguns rows sem match
  FAILED // erro de parsing ou validação
}

enum VeterinaryReportGroup {
  EMPTY_NORMAL_45D // matrizes vazias normais com mais de 45 dias paridas
  EMPTY_LATE // matrizes vazias atrasadas
  DRY_EMPTY // matrizes secas vazias
  INSEMINATED_OVER_30D // matrizes inseminadas há mais de 30 dias
  TO_DRY // matrizes a secar
  PREGNANT_HEIFER // novilhas gestantes
  LACTATING_PREGNANT // matrizes em lactação gestantes
  DRY_PREGNANT // matrizes secas gestantes
  CLOSE_UP // matrizes amojadas (pré-parto iminente)
  UNKNOWN // grupo não identificado
}

enum VeterinaryDayMeaning {
  DAYS_POSTPARTUM // dias pós-parto
